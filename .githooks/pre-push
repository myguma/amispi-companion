#!/usr/bin/env bash
# タグ push 前に注意喚起する
# Windows ターゲットのチェックは CI (check.yml) が main push 時に自動実行する

set -euo pipefail

pushing_tag=false
while read -r local_ref _local_sha _remote_ref _remote_sha; do
  if [[ "$local_ref" == refs/tags/* ]]; then
    pushing_tag=true
  fi
done

if [ "$pushing_tag" != true ]; then
  exit 0
fi

# タグ push 前に最新 main の check CI が通っているか確認
echo "[pre-push] タグ push を検出"

if command -v gh &>/dev/null; then
  latest=$(gh run list --repo "$(git remote get-url origin | sed 's/.*github.com[:/]//' | sed 's/\.git$//')" \
    --workflow check.yml --branch main --limit 1 --json conclusion --jq '.[0].conclusion' 2>/dev/null || echo "unknown")

  if [ "$latest" = "failure" ]; then
    echo "[pre-push] ⚠ 直近の Windows チェックが失敗しています"
    echo "  https://github.com/$(git remote get-url origin | sed 's/.*github.com[:/]//' | sed 's/\.git$//')/actions"
    echo "  修正後に再 push してください (スキップするには: git push --no-verify)"
    exit 1
  elif [ "$latest" = "success" ]; then
    echo "[pre-push] ✓ Windows チェック OK"
  else
    echo "[pre-push] チェック結果が不明のため通過します (status: $latest)"
  fi
fi
